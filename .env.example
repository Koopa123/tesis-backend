# ── Base de datos ─────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI
# Si tu contraseña tiene caracteres especiales, encodéalos: @ → %40  # → %23  % → %25
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar secreto seguro:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend (sin barra final). En dev puede ser localhost:3000 o :5173
FRONTEND_URL=http://localhost:5173

# ── Seed del administrador (solo para scripts/seed_admin.py) ─────────────────
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@correo.com
ADMIN_PASSWORD=cambia_esta_contraseña
